local Button = MainTab:CreateButton({
   Name = "Auto Aim",
   Callback = function()
        local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CAS = game:GetService("ContextActionService")

-- [[ CONFIGURATION ]] --
local HARPOON_SPEED = 150
local RANGE = 200
local BASE_LOCATION = Vector3.new(0, 10, 0) -- Change this to your Base's Position!
local TARGET_TAG = "Brainrot" -- Put this tag on your enemies

local player = Players.LocalPlayer
local tool = script.Parent
local handle = tool:WaitForChild("Handle")
local isLocked = false

-- [[ FIND THE SIGMA ]] --
local function getTarget()
	local closest = nil
	local dist = RANGE
	for _, v in pairs(workspace:GetChildren()) do
		local hum = v:FindFirstChild("Humanoid")
		local hrp = v:FindFirstChild("HumanoidRootPart")
		if hrp and hum and v ~= player.Character and hum.Health > 0 then
			local d = (hrp.Position - handle.Position).Magnitude
			if d < dist then
				dist = d
				closest = hrp
			end
		end
	end
	return closest
end

-- [[ THE AIMBOT LOGIC ]] --
RunService.RenderStepped:Connect(function()
	if isLocked then
		local target = getTarget()
		if target then
			-- Calculate Lead (Where they will be)
			local travelTime = (target.Position - handle.Position).Magnitude / HARPOON_SPEED
			local predictedPos = target.Position + (target.AssemblyLinearVelocity * travelTime)
			
			-- Instant Snap Aim
			handle.CFrame = CFrame.lookAt(handle.Position, predictedPos)
		end
	end
end)

-- [[ AUTO-TP ON HIT ]] --
-- This detects when the harpoon in your hand touches a target
handle.Touched:Connect(function(hit)
	local enemy = hit.Parent
	if enemy:FindFirstChild("Humanoid") and enemy ~= player.Character then
		print("Target Secured! Teleporting to Base...")
		
		-- Teleport Player back to Base
		local hrp = player.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.CFrame = CFrame.new(BASE_LOCATION)
		end
	end
end)

-- [[ MOBILE BUTTON SETUP ]] --
local function onButtonPress(actionName, inputState)
	if inputState == Enum.UserInputState.Begin then
		isLocked = not isLocked
		print(isLocked and "Aura Locked" or "Aura Lost")
	end
end

tool.Equipped:Connect(function()
	CAS:BindAction("LockOn", onButtonPress, true, Enum.KeyCode.F)
	CAS:SetTitle("LockOn", "LOCK 🎯") -- This creates the mobile button
end)

tool.Unequipped:Connect(function()
	CAS:UnbindAction("LockOn")
	isLocked = false
end)
   end,
