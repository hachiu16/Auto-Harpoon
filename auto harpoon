-- [[ CONFIG ]] --
local RANGE = 500 -- Max range for Infinity spawns
local HARPOON_SPEED = 220 -- Fast projectile speed for the gamepass gun
local LOCK_KEY = Enum.KeyCode.F

local tool = script.Parent
local handle = tool:WaitForChild("Handle")
local player = Players.LocalPlayer
local isLocked = false

-- [[ SEARCH LOGIC ]] --
local function getBestBrainrot()
	local closest, shortestDist = nil, RANGE
	
	-- Scan all descendants to find hidden Infinity spawns
	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and TARGET_NAMES[obj.Name] then
			local hrp = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
			if hrp then
				local dist = (hrp.Position - handle.Position).Magnitude
				if dist < shortestDist then
					shortestDist = dist
					closest = hrp
				end
			end
		end
	end
	return closest
end

-- [[ THE AIMBOT LOOP ]] --
RunService.RenderStepped:Connect(function()
	if isLocked and handle then
		local target = getBestBrainrot()
		if target then
			-- Calculate Lead Time (Infinity Brainrots can be jittery)
			local travelTime = (target.Position - handle.Position).Magnitude / HARPOON_SPEED
			local velocity = target.AssemblyLinearVelocity or Vector3.new(0,0,0)
			local predictedPos = target.Position + (velocity * travelTime)
			
			-- Smooth LookAt to keep it looking "Legit"
			local lookCF = CFrame.lookAt(handle.Position, predictedPos)
			handle.CFrame = handle.CFrame:Lerp(lookCF, 0.2) -- 0.2 for smooth, 1.0 for instant snap
		end
	end
end)

-- [[ MOBILE BUTTON & PC TOGGLE ]] --
local function onAction(actionName, inputState)
	if inputState == Enum.UserInputState.Begin then
		isLocked = not isLocked
		print(isLocked and "FARMING INFINITY..." or "AURA LOST")
	end
	return Enum.ContextActionResult.Success
end

tool.Equipped:Connect(function()
	CAS:BindAction("HarpoonLock", onAction, true, LOCK_KEY)
	CAS:SetTitle("HarpoonLock", "🎯 LOCK")
end)

tool.Unequipped:Connect(function()
	CAS:UnbindAction("HarpoonLock")
	isLocked = false
end)
