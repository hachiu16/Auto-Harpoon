local player = Players.LocalPlayer
local isLocked = false

-- [[ NEW: ENHANCED BRAINROT DETECTOR ]] --
local function isTargetable(obj)
    -- Ignore players and the wave
    if Players:GetPlayerFromCharacter(obj.Parent) or obj.Name == "Tsunami" then return false end
    
    -- In Escape Tsunami, collectables are usually Models or Parts with "Brainrot" in the name
    -- Or they have a ProximityPrompt to pick them up
    if obj:IsA("Model") or obj:IsA("BasePart") then
        if obj:FindFirstChildOfClass("ProximityPrompt") or string.find(string.lower(obj.Name), "rot") then
            return true
        end
    end
    return false
end

-- [[ SCAN THE CORRIDOR ]] --
local function findTheBrainrot()
    local closest, shortestDist = nil, RANGE
    
    -- We scan Workspace and also common folders like "DroppedItems" or "Spawns"
    for _, obj in pairs(workspace:GetDescendants()) do
        if isTargetable(obj) then
            local pos = obj:IsA("Model") and (obj.PrimaryPart and obj.PrimaryPart.Position or obj:GetModelCFrame().Position) or obj.Position
            local dist = (pos - handle.Position).Magnitude
            
            if dist < shortestDist then
                shortestDist = dist
                closest = obj
            end
        end
    end
    return closest
end

-- [[ THE AIMBOT ]] --
RunService.RenderStepped:Connect(function()
    if isLocked and handle then
        local target = findTheBrainrot()
        
        if target then
            local targetPos = target:IsA("Model") and (target.PrimaryPart and target.PrimaryPart.Position or target:GetModelCFrame().Position) or target.Position
            
            -- Snap the harpoon directly to the target's center
            handle.CFrame = CFrame.lookAt(handle.Position, targetPos)
        end
    end
end)

-- [[ CONTROLS ]] --
local function onAction(actionName, inputState)
    if inputState == Enum.UserInputState.Begin then
        isLocked = not isLocked
        print(isLocked and "LOCKING IN..." or "UNLOCK")
    end
    return Enum.ContextActionResult.Success
end

tool.Equipped:Connect(function()
    CAS:BindAction("HarpoonLock", onAction, true, LOCK_KEY)
